{{!< default}}

<main id="main-content" class="gh-main wc-main">
    {{!-- Hero zone: galaxy bg via CSS background-image, extends behind wave divider + hero --}}
    <div class="wc-hero-zone">
        {{!-- Wave divider between navbar and hero (homepage only) --}}
        <div class="wc-wave-divider">
            <img src="{{asset "images/ui-wave-divider-light.svg"}}" alt="" aria-hidden="true">
        </div>

        {{> "components/home-hero"}}
    </div>

    {{!-- Green rule between hero and podcast services --}}
    <hr class="wc-rule wc-rule--thick">

    {{> "podcast-services"}}

    {{!-- Green rule below podcast services --}}
    <hr class="wc-rule">

    <section class="gh-archive gh-outer">
        <div class="gh-archive-inner gh-inner">
            <header class="gh-archive-header">
                <h1 class="gh-archive-title">LATEST EPISODES</h1>
            </header>
        </div>
    </section>

    {{!-- Episodes with highlight zones injected between items --}}
    <div class="gh-list simple gh-outer">
        <div class="gh-list-inner gh-inner">
            <div class="gh-list-feed">
                {{#get "posts" include="tags,authors" filter="tag:-newsletter+tag:-luminous" limit="5"}}
                    {{#foreach posts}}
                        {{> components/list-item showExcerpt=true showPublishedAt=true}}

                        {{!-- Highlight Zone 1: Latest Newsletter (after 2nd episode) --}}
                        {{#match @index "==" 1}}
                            {{> "components/highlight-zone"
                                tagFilter="tag:newsletter+featured:true"
                                badgeLabel="Latest Newsletter"
                                badgeUrl="/tag/newsletter/"
                                accentClass="wc-highlight--newsletter"
                            }}
                        {{/match}}

                        {{!-- Highlight Zone 2: Special Series (after 3rd episode) --}}
                        {{#match @index "==" 2}}
                            {{> "components/highlight-zone"
                                tagFilter="tag:island-of-knowledge+featured:true"
                                badgeLabel="Island of Knowledge"
                                badgeUrl="/tag/island-of-knowledge/"
                                accentClass="wc-highlight--series"
                            }}
                        {{/match}}

                        {{!-- Highlight Zone 3: Latest Luminous (after 4th episode) --}}
                        {{#match @index "==" 3}}
                            {{> "components/highlight-zone"
                                tagFilter="tag:luminous+featured:true"
                                badgeLabel="From Luminous"
                                badgeUrl="/tag/luminous/"
                                accentClass="wc-highlight--luminous"
                            }}
                        {{/match}}
                    {{/foreach}}
                {{/get}}
            </div>
        </div>
    </div>

    {{!-- Green rule after episodes --}}
    <hr class="wc-rule">

    {{#match pagination.pages ">" 1}}
        <nav class="wc-pagination wc-pagination--home gh-outer" aria-label="More episodes">
            <div class="wc-pagination-inner gh-inner">
                <a class="wc-pagination-link wc-pagination-link--centered" href="{{page_url pagination.next}}">
                    More Episodes &rarr;
                </a>
            </div>
        </nav>
    {{/match}}
    {{> "components/cta" title=@custom.email_signup_text}}
</main>